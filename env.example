# --- Required in production ---

# Provided by the Railway Postgres plugin. Locally: your own connection string.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Long random string used to sign session cookies.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Optional ---

# 'production' or 'development'. Railway sets this automatically.
NODE_ENV=development

# Local dev port (Railway injects PORT; do not override there).
PORT=3000

# Override the session cookie name if you like.
COOKIE_NAME=bbqa.sid
